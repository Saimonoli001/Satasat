<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Satasat – Peer-to-Peer Skill Exchange Platform</display-name>

    <!-- Welcome page -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Block direct JSP access; all traffic must go through servlets -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Block Direct JSP</web-resource-name>
            <url-pattern>/views/*</url-pattern>
        </web-resource-collection>
        <auth-constraint/>
    </security-constraint>

    <!-- Custom error pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/views/pages/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/views/pages/error.jsp</location>
    </error-page>

</web-app>
